# ── Yuri Tutor — Environment Variables Template ───────────────────────────────
# Copy this file to env.js (gitignored) and fill in real values.
# For Netlify: add these as Environment Variables in the dashboard.
#
# Inject into the app by adding a <script> before your modules in index.html
# and admin.html:
#
#   <script>
#     window.__ENV = {
#       FIREBASE_API_KEY:      "...",
#       FIREBASE_AUTH_DOMAIN:  "...",
#       FIREBASE_DATABASE_URL: "...",
#       FIREBASE_PROJECT_ID:   "...",
#       BANK_ID:               "MB",
#       BANK_ACCOUNT_NO:       "...",
#       BANK_ACCOUNT_NAME:     "...",
#       PASSCODE_SUFFIX:       "2024"
#     };
#   </script>
# ─────────────────────────────────────────────────────────────────────────────

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=

# Thanh toán học phí (VietQR)
BANK_ID=MB
BANK_ACCOUNT_NO=
BANK_ACCOUNT_NAME=

# Suffix dùng để tạo dummy Firebase Auth password từ passcode gia đình
PASSCODE_SUFFIX=
